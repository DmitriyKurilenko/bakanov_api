# Production template (server deploy)

SECRET_KEY=replace-with-long-random-secret
DEBUG=false
ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com

SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

DOMAIN=api.example.com
WWW_DOMAIN=
CERTBOT_EMAIL=ops@example.com
# Optional deploy override (defaults to DOMAIN or first ALLOWED_HOSTS value)
HEALTHCHECK_HOST=api.example.com

POSTGRES_DB=bakanov
POSTGRES_USER=bakanov
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

AMOCRM_BASE_URL=https://example.amocrm.ru
AMOCRM_ACCESS_TOKEN=change-me
AMOCRM_REDIRECT_URI=https://api.example.com/api/integrations/amocrm/oauth/callback
AMOCRM_PIPELINE_ID=
AMOCRM_RESPONSIBLE_GROUP_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
DOCUMENTS_EMAIL_TO=

DEEPGRAM_API_KEY=
YANDEX_API_KEY=
YANDEX_MODEL_URI=
YANDEX_METRIKA_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_METRIKA_OFFLINE_GOAL_ID=spam_lead
YANDEX_METRIKA_UPLOAD_TYPE=BASIC

AMOCRM_SPAM_CLIENT_ID_FIELD_IDS=952089
AMOCRM_SPAM_CLIENT_ID_FIELD_CODES=
AMOCRM_SPAM_CLIENT_ID_FIELD_NAMES=yandex_id,client_id
STT_PROVIDER=deepgram

CONTRACT_HTML_TEMPLATE=contracts/contract.html
CONTRACT_HTML_TEMPLATE_U=contracts/contract_u.html
EXTRA_CONTRACT_HTML_TEMPLATE=contracts/extra_contract.html
CONTRACT_EUR_RATE=100
CONTRACT_FILE_FIELD_ID=0
EXTRA_CONTRACT_FILE_FIELD_ID=0

GOOGLE_FORMS_WEBHOOK_SECRET=
GOOGLE_FORMS_TEST_LEAD_ID=0
